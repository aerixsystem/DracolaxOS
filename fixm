import os

def fix_makefile(filename="Makefile"):
    if not os.path.exists(filename):
        print(f"❌ Error: {filename} not found!")
        return

    with open(filename, 'r') as f:
        lines = f.readlines()

    fixed_lines = []
    in_git_target = False

    for line in lines:
        # Check if we reached the git target header
        if line.startswith("git:"):
            in_git_target = True
            fixed_lines.append(line)
            continue
        
        # If we are inside the git target and the line starts with spaces
        if in_git_target:
            if line.startswith("  ") or line.startswith("    "):
                # Strip leading whitespace and replace with a single Tab
                fixed_lines.append("\t" + line.lstrip())
            elif line.strip() == "" or ":" in line:
                # If it's an empty line or a new target, we've left the git section
                in_git_target = False
                fixed_lines.append(line)
            else:
                fixed_lines.append(line)
        else:
            fixed_lines.append(line)

    with open(filename, 'w') as f:
        f.writelines(fixed_lines)
    
    print(f"✅ Tabs restored in {filename}! Try running 'make git' now. 🚀")

if __name__ == "__main__":
    fix_makefile()
