{
  "name": "calculator",
  "display_name": "Calculator",
  "version": "1.0.0",
  "description": "Simple integer calculator for DracolaxOS shell.",
  "author": "Lunax",
  "license": "MIT",
  "entry": "calculator",
  "type": "cli",
  "requirements": {
    "os_version": ">=2.0",
    "memory_kb": 128,
    "syscalls": ["read", "write", "exit"]
  },
  "install_path": "/storage/apps/calculator",
