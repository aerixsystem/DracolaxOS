{
  "name": "hello-world",
  "display_name": "Hello World",
  "version": "1.0.0",
  "description": "Minimal DracolaxOS example application.",
  "author": "Lunax",
  "license": "MIT",
  "entry": "hello-world",
  "type": "cli",
  "requirements": {
    "os_version": ">=2.0",
    "memory_kb": 64,
    "syscalls": ["write", "exit"]
  },
  "install_path": "/storage/apps/hello-world",
  "tags": ["example", "demo"],
  "node_id": "05",
  "storage": {
    "data":    "/storage/apps/hello-world/data",
    "configs": "/storage/apps/hello-world/configs",
    "cache":   "/storage/apps/hello-world/cache"
  }
}
